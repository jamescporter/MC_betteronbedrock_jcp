{
	"format_version": "1.8.0",
	"minecraft:attachable": {
		"description": {
			"identifier": "better_on_bedrock:amethyst_leggings",
			// Notice this is the same as before
			"materials": {
				"default": "armor",
				"enchanted": "armor_enchanted"
			},
			"textures": {
				"default": "textures/models/armor/amethyst_legs",
				"enchanted": "textures/misc/enchanted_actor_glint",
                "baby": "textures/models/armor/amethyst_legs"
			},
			// Tell it to use leggings geom
			"geometry": {
				"default": "geometry.humanoid.armor.leggings",
                "baby": "geometry.humanoid.baby.armor.leggings"
			},
			// Hide legs layer as we will be rendering over it
			"scripts": {
				"parent_setup": "variable.leg_layer_visible = 0.0;",
                "pre_animation": [
                    "variable.use_baby_geo = query.is_baby && c.owning_entity->v.use_dedicated_baby_armor;"
                ]
			},
			// Same as before
			"render_controllers": ["controller.render.armor"]
		}
	}
}
