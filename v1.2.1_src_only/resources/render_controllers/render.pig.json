{
    "format_version": "1.8.0",
    "render_controllers": {
        "controller.render.pig.v4": {
            "arrays": {
                "textures": {
                    "Array.default": [
                        "Texture.default",
                        "Texture.warm",
                        "Texture.cold"
                    ],
                    "Array.baby": [
                        "Texture.baby_default",
                        "Texture.baby_warm",
                        "Texture.baby_cold"
                    ]
                }
            },
            "geometry": "query.is_baby ? Geometry.baby : Geometry.default",
            "materials": [
                { "*": "q.property('better_on_bedrock:enchanted') ? Material.enchanted_rtx : Material.default" }
            ],
            "textures": [
                "query.is_baby ? Array.baby[v.index] : Array.default[v.index]",
                "Texture.enchanted"
            ],
            "overlay_color": {
                "r": 1.0,
                "g": 0.0,
                "b": 0.957,
                "a": "q.property('better_on_bedrock:enchanted') ? 0.25 : 0.0"
            }
        }
    }
}