{
    "format_version": "1.10.0",
    "minecraft:client_entity": {
        "description": {
            "identifier": "better_on_bedrock:pale_pumkin_eye",
            "materials": {
                "default": "entity_emissive_alpha"
            },
            "geometry": {
                "default": "geometry.pale_eye_effect"
            },
            "textures": {
                "default": "textures/particle/pale_eye_front_emissive"
            },
            "animations": {
                "north": "animation.pale_pumpkin_eye.north",
                "east": "animation.pale_pumpkin_eye.east",
                "west": "animation.pale_pumpkin_eye.west",
                "south": "animation.pale_pumpkin_eye.south"
            },
            "scripts": {
                "animate": [
                    { "north": "query.property('pog:rotation') == 'north'" },
                    { "east": "query.property('pog:rotation') == 'east'" },
                    { "west": "query.property('pog:rotation') == 'west'" },
                    { "south": "query.property('pog:rotation') == 'south'" }
                ],
                "should_update_bones_and_effects_offscreen": true
            },
            "render_controllers": [ "controller.render.default" ]
        }
    }
}