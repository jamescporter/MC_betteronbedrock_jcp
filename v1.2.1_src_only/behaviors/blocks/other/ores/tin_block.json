{
    "format_version": "1.21.40",
    "minecraft:block": {
        "description": {
            "identifier": "better_on_bedrock:tin_block",
            "menu_category": {
                "category": "construction",
                "group": "itemGroup.name.oreBlocks"
            }
        },
        "components": {
            "minecraft:geometry": {
                "identifier": "geometry.full_block",
                "culling": "better_on_bedrock:cube"
            },
            "minecraft:material_instances": {
                "*": {
                    "texture": "better_on_bedrock:tin_block"
                }
            },

            "minecraft:destructible_by_explosion": false,
            "minecraft:destructible_by_mining": {
                "seconds_to_destroy": 5,
                "item_specific_speeds": [
                    {
                        "item": {
                            "tags": "query.all_tags('minecraft:is_pickaxe') && query.any_tag('minecraft:stone_tier','minecraft:golden_tier')"
                        },
                        "destroy_speed": 1.5
                    },
                    {
                        "item": {
                            "tags": "query.all_tags('minecraft:is_pickaxe') && query.any_tag('minecraft:copper_tier','minecraft:iron_tier')"
                        },
                        "destroy_speed": 1.25
                    },
                    {
                        "item": {
                            "tags": "query.all_tags('minecraft:is_pickaxe','minecraft:diamond_tier')"
                        },
                        "destroy_speed": 1
                    },
                    {
                        "item": {
                            "tags": "query.all_tags('minecraft:is_pickaxe','minecraft:netherite_tier')"
                        },
                        "destroy_speed": 0.75
                    }
                ]
            },

            "tag:metal": {},
            "tag:diamond_pick_diggable": {}
        }
    }
}