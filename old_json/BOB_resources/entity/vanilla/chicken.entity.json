{
  "format_version": "1.10.0",
  "minecraft:client_entity": {
    "description": {
      "identifier": "minecraft:chicken",
      "min_engine_version": "1.12.0",
      "materials": {
        "default": "chicken",
        "cold": "chicken_cold",
        "legs": "chicken_legs",
        "enchanted": "entity_enchant",
        "enchanted_rtx": "entity_alphatest_glint"
      },
      "textures": {
        "default": "textures/entity/chicken/chicken",
        "warm": "textures/entity/chicken/chicken_warm",
        "cold": "textures/entity/chicken/chicken_cold",
        "enchanted": "textures/misc/enchanted_glint_entity"
      },
      "geometry": {
        "default": "geometry.chicken.v1.12",
        "warm": "geometry.chicken.v1.12",
        "cold": "geometry.chicken.cold"
      },
      "scripts": {
        "pre_animation": [
          "t.variant = query.property('minecraft:climate_variant');",
          "v.index = (t.variant == 'temperate') ? 0 : ((t.variant == 'warm') ? 1 : 2);",
          "v.is_cold = t.variant == 'cold';"
        ],
        "should_update_bones_and_effects_offscreen": true
      },
      "render_controllers": [
        "controller.render.chicken.v2",
        {
          "controller.render.enchanted": "q.property('better_on_bedrock:enchanted') && !q.graphics_mode_is_any('raytraced')"
        }
      ],
      "spawn_egg": {
        "texture": "spawn_egg_chicken"
      }
    }
  }
}