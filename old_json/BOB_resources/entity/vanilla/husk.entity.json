{
  "format_version": "1.10.0",
  "minecraft:client_entity": {
    "description": {
      "identifier": "minecraft:husk",
      "min_engine_version": "1.12.0",
      "materials": {
        "enchanted": "entity_enchant",
        "enchanted_rtx": "entity_alphatest_glint"
      },
      "textures": {
        "enchanted": "textures/misc/enchanted_glint_entity"
      },
      "scripts": {
        "pre_animation": [
          "variable.tcos0 = (Math.cos(query.modified_distance_moved * 38.17) * query.modified_move_speed / variable.gliding_speed_value) * 57.3;",
          // Melee spear
          "v.melee_spear_equipped = query.equipped_item_any_tag('slot.weapon.mainhand', 'minecraft:spear');"
        ],
        "should_update_bones_and_effects_offscreen": true
      },
      "render_controllers": [
        "controller.render.husk",
        {
          "controller.render.enchanted": "q.property('better_on_bedrock:enchanted') && !q.graphics_mode_is_any('raytraced')"
        }
      ],
      "enable_attachables": true
    }
  }
}