{
    "chest_label": {
        "$new_container_title|default": "$container_title",
        "text": "$new_container_title"
    },
    "small_root_panel@common.root_panel": {
        "layer": 1,
        "$chest_panel|default": "chest.small_chest_panel_top_half",
        "controls": [
            { "common_panel@common.common_panel": {} },
            {
                "chest_panel": {
                    "type": "panel",
                    "layer": 5,
                    "controls": [
                        { "small_chest_panel_top_half@$chest_panel": {} },
                        { "inventory_panel_bottom_half_with_label@common.inventory_panel_bottom_half_with_label": {} },
                        { "hotbar_grid@common.hotbar_grid_template": {} },
                        { "inventory_take_progress_icon_button@common.inventory_take_progress_icon_button": {} }
                    ]
                }
            },
            { "inventory_selected_icon_button@common.inventory_selected_icon_button": {} },
            { "gamepad_cursor@common.gamepad_cursor_button": {} }
        ]
    },

    "small_chest_panel/root_panel": { "ignored": true },
    "small_chest_panel": {
        "$root_panel|default": "chest.small_root_panel",
        "modifications": [
            {
                "array_name": "controls",
                "operation": "insert_back",
                "value": { "panel@$root_panel": {} }
            }
        ]
    },

    "9_grid": {
        "type": "grid",
        "size": [162, 45],
        "anchor_from": "top_left",
        "anchor_to": "top_left",
        "grid_dimensions": [9, 2],
        "grid_item_template": "chest.chest_grid_item",
        "collection_name": "container_items"
    },
    "36_grid": {
        "type": "grid",
        "size": [162, 72],
        "anchor_from": "top_left",
        "anchor_to": "top_left",
        "grid_dimensions": [9, 4],
        "grid_item_template": "chest.chest_grid_item",
        "collection_name": "container_items"
    },
    "54_grid": {
        "type": "grid",
        "size": [162, 108],
        "anchor_from": "top_left",
        "anchor_to": "top_left",
        "grid_dimensions": [9, 6],
        "grid_item_template": "chest.chest_grid_item",
        "collection_name": "container_items"
    },

    "9_panel_top_half": {
        "type": "panel",
        "size": ["100%", "50%"],
        "offset": [0, 11],
        "anchor_to": "top_left",
        "anchor_from": "top_left",
        "controls": [
            { "chest_label@chest.chest_label": {} },
            { "large_chest_grid@chest.9_grid": { "offset": [7, 9] } }
        ]
    },
    "36_panel_top_half": {
        "type": "panel",
        "size": ["100%", 16],
        "offset": [0, 11],
        "anchor_to": "top_left",
        "anchor_from": "top_left",
        "controls": [
            { "chest_label@chest.chest_label": {} },
            { "large_chest_grid@chest.36_grid": { "offset": [7, 9] } }
        ]
    },
    "54_panel_top_half": {
        "type": "panel",
        "size": ["100%", 132],
        "offset": [0, 11],
        "anchor_to": "top_left",
        "anchor_from": "top_left",
        "controls": [
            { "chest_label@chest.chest_label": {} },
            { "large_chest_grid@chest.54_grid": { "offset": [7, 9] } }
        ]
    },

    "9_root_panel@chest.small_root_panel": {
        "size": [176, 150],
        "$chest_panel": "chest.9_panel_top_half"
    },
    "36_root_panel@chest.small_root_panel": {
        "size": [176, 180],
        "$chest_panel": "chest.36_panel_top_half"
    },
    "54_root_panel@chest.small_root_panel": {
        "size": [176, 220],
        "$chest_panel": "chest.54_panel_top_half"
    },

    "small_chest_screen": {
        "$fart": "$container_title",
        "$new_container_title|default": "$container_title",
        "$container_size|default": 27,
        "modifications": [
            {
                "array_name": "variables",
                "operation": "insert_back",
                "value": [
                    {
                        "requires": "(not (($fart - 'Corpse') = $fart))",
                        "$root_panel": "chest.54_root_panel",
                        "$container_size": 54
                    },
                    {
                        "requires": "($fart = 'Backpack')",
                        "$root_panel": "chest.9_root_panel",
                        "$container_size": 18
                    },
                    {
                        "requires": "($fart = 'Medium Backpack')",
                        "$root_panel": "chest.36_root_panel",
                        "$container_size": 36
                    },
                    {
                        "requires": "($fart = 'Large Backpack')",
                        "$root_panel": "chest.54_root_panel",
                        "$container_size": 54
                    },
                    {
                        "requires": "$desktop_screen",
                        "$screen_content": "chest.small_chest_panel",
                        "$screen_bg_content": "common.screen_background"
                    },
                    {
                        "requires": "$pocket_screen",
                        "$container_title": "$new_container_title",
                        "$screen_content": "pocket_containers.panel"
                    }
                ]
            }
        ]
    }
}