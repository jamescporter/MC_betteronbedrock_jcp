{
	"format_version": "1.19.0",
	"animation_controllers": {
		"controller.animation.deer.all": {
			"states": {
			"default" : {
					"animations" : [
						{
							"move" : "query.modified_move_speed"
						},
						"look_at_player"
					],
					"transitions" : [
						{
							"grazing" : "query.is_grazing"
						}
					]
				},
				"grazing" : {
					"animations" : [ "eat" ],
					"transitions" : [
						{
							"default" : "query.all_animations_finished"
						}
					]
				}
			}
		}
	}
}
