						"despawn"
					]
				}
			},
			"minecraft:entity_spawned": {
				"queue_command": {
					"command": [
						"tag @s add bob:seeker_launcher_active",
						"particle pog:seeker_launch_base ~ ~ ~",
						"particle pog:seeker_launch_ambient ~ ~ ~"
					]
				},
				"add": {
					"component_groups": [
						"stugg"
					]
				}
