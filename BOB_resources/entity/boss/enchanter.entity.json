{
	"format_version": "1.10.0",
	"minecraft:client_entity": {
		"description": {
			"identifier": "better_on_bedrock:enchantaegis",
			"materials": {
				"default": "entity_alphatest",
				"enchanted": "entity_enchant",
				"enchanted_rtx": "entity_alphatest_glint"
			},
			"textures": {
				"default": "textures/entity/bosses/enchanter/enchanter",
				"enchanted": "textures/misc/enchanted_glint_entity"
			},
			"geometry": {
				"default": "geometry.enchanter"
			},
			"animations": {
				"basic": "controller.animation.enchanter.moves",
				"attack": "animation.enchanter.attack",
				"idle": "animation.enchanter.idle",
				"walk": "animation.enchanter.walk",
				"enchant": "animation.enchanter.enchant"
			},
			"sound_effects": {
				"iceologer_magic": "mob.enchanter.magic"
			},
			"scripts": {
				"pre_animation": [
					"variable.is_enchanted = query.mark_variant == 1;"
				],
				"animate": [
					"basic"
				],
				"should_update_bones_and_effects_offscreen": true
			},
			"render_controllers": [
				"controller.render.enchanter",
				{
					"controller.render.enchanted_enchanter": "q.mark_variant == 1 && !q.graphics_mode_is_any('raytraced')"
				}
			],
			"spawn_egg": {
				"texture": "spawn_egg_enchantaegis"
			}
		}
	}
}