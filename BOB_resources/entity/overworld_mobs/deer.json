{
	"format_version": "1.10.0",
	"minecraft:client_entity": {
		"description": {
			"identifier": "better_on_bedrock:deer",
			"materials": {
				"default": "entity_alphatest",
				"enchanted": "entity_enchant",
				"enchanted_rtx": "entity_alphatest_glint"
			},
			"textures": {
				"default": "textures/entity/overworld/deer",
				"doe": "textures/entity/overworld/deer",
				"enchanted": "textures/misc/enchanted_glint_entity_TESTED"
			},
			"animations": {
				"basic": "controller.animation.deer.all",
				"move": "animation.deer.move",
				"idle": "animation.deer.idle",
				"eat": "animation.deer.eat",
				"baby": "animation.deer.baby_transform",
				"look_at_player": "animation.common.look_at_target"
			},
			"scripts": {
				"animate": [
					"basic",
					{
						"baby": "q.is_baby"
					}
				],
				"should_update_bones_and_effects_offscreen": true
			},
			"geometry": {
				"default": "geometry.deer",
				"doe": "geometry.doe"
			},
			"render_controllers": [
				"controller.render.deer",
				{
					"controller.render.enchanted": "q.property('better_on_bedrock:enchanted') && !q.graphics_mode_is_any('raytraced')"
				}
			],
			"spawn_egg": {
				"texture": "spawn_egg_deer"
			}
		}
	}
}