{
  "format_version": "1.8.0",
  "render_controllers": {
    "controller.render.evoker": {
      "geometry": "Geometry.default",
      "materials": [ { "*": "q.property('better_on_bedrock:enchanted') ? Material.enchanted_rtx : Material.default" } ],
      "part_visibility": [
        { "*": true },
        { "arms": "!(query.is_casting || query.is_celebrating)" },
        { "leftarm": "query.is_casting || query.is_celebrating" },
        { "rightarm": "query.is_casting || query.is_celebrating" }
      ],
      "textures": [ "Texture.default", "Texture.enchanted" ],
      "color": {
        "r": 1.0,
        "g": 1.0,
        "b": 1.0,
        "a": 1.0
      },
      "overlay_color": {
        "r": 1.0,
        "g": 0.0,
        "b": 0.957,
        "a": "q.property('better_on_bedrock:enchanted') ? 0.25 : 0.0"
      }
    }
  }
}