{
    "format_version": "1.8.0",
    "render_controllers": {
        "controller.render.zombie": {
            "arrays": {
                "geometries": {
                    "Array.geos": [
                        "Geometry.default",
                        "Geometry.warm",
                        "Geometry.cold"
                    ]
                },
                "textures": {
                    "Array.textures": [
                        "Texture.default",
                        "Texture.warm",
                        "Texture.cold"
                    ]
                }
            },

            "geometry": "query.is_baby ? Geometry.baby : Array.geos[v.index]",
            "materials": [
                { "*": "q.property('better_on_bedrock:enchanted') ? Material.enchanted_rtx : Material.default" }
            ],
            "textures": [
                "query.is_baby ? Texture.baby : Array.textures[v.index]",
                "Texture.enchanted"
            ],
            "overlay_color": {
                "r": 1.0,
                "g": 0.0,
                "b": 0.957,
                "a": "q.property('better_on_bedrock:enchanted') ? 0.25 : 0.0"
            }
        },
        "controller.render.zombie.v2": {
            "geometry": "query.is_baby ? Geometry.baby : Geometry.default",
            "materials": [
                { "*": "q.property('better_on_bedrock:enchanted') ? Material.enchanted_rtx : Material.default" }
            ],
            "textures": [
                "query.is_baby ? Texture.baby : Texture.default",
                "Texture.enchanted"
            ],
            "overlay_color": {
                "r": 1.0,
                "g": 0.0,
                "b": 0.957,
                "a": "q.property('better_on_bedrock:enchanted') ? 0.25 : 0.0"
            }
        }
    }
}