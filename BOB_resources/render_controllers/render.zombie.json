{
    "format_version": "1.8.0",
    "render_controllers": {
      "controller.render.zombie": {
        "arrays": {
           "geometries": {
          "Array.geos": [
            "Geometry.default",
            "Geometry.warm",
            "Geometry.cold"
          ]
        },
        "textures": {
            "Array.textures": [
              "Texture.default",
              "Texture.warm",
              "Texture.cold"
            ]
          }
        },

        "geometry": "Array.geos[v.index]",
        "materials": [ { "*": "q.property('better_on_bedrock:enchanted') ? Material.enchanted_rtx : Material.default" } ],
        "textures": [ "Array.textures[v.index]", "Texture.enchanted" ],
        "overlay_color": {
          "r": 1.0,
          "g": 0.0,
          "b": 0.957,
          "a": "q.property('better_on_bedrock:enchanted') ? 0.25 : 0.0"
        }
      }
    }
  }
  
  