{
  "format_version": "1.8.0",
  "render_controllers": {
    "controller.render.phantom": {
      "arrays": {
        "textures": {
          "array.textures": [ "texture.default", "texture.invisible" ]
        }
      },
      "geometry": "geometry.default",
      "materials": [{ "*": "q.property('better_on_bedrock:enchanted') ? material.enchanted_rtx : material.default" }],
      "textures": [ "array.textures[query.is_invisible]", "texture.enchanted" ],
      "overlay_color": {
        "r": 1.0,
        "g": 0.0,
        "b": 0.957,
        "a": "q.property('better_on_bedrock:enchanted') ? 0.25 : 0.0"
      }
    }
  }
}