{
    "format_version": "1.21.80",
    "minecraft:attachable": {
        "description": {
            "identifier": "better_on_bedrock:blade_of_the_nether.ans",
            "item": {
                "better_on_bedrock:blade_of_the_nether": "(c.owning_entity ?? false) ? c.owning_entity->v.actions_and_stuff;"
            },
            
            "materials": {
                "default": "entity_alphatest",
                "enchanted": "entity_alphatest_glint"
            },
            "textures": {
                "default": "textures/items/tools/blade_of_the_nether",
                "enchanted": "textures/misc/enchanted_item_glint"
            },
            "geometry": {
                "default": "geometry.texture_mesh"
            },

            "scripts": {
                "parent_setup": "
                    c.item_slot == 'main_hand' ? { v.oreville_mainhand_custom_pos = 1; v.oreville_mainhand_visible  = 1;};
                    c.item_slot == 'off_hand' ? { v.oreville_offhand_custom_pos = 1; v.oreville_offhand_visible  = 1;};
                "
            },
            "render_controllers": [ "controller.render.item_sprite" ]
        }
    }
}