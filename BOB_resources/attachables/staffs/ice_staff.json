{
    "format_version": "1.10.0",
    "minecraft:attachable": {
        "description": {
            "identifier": "better_on_bedrock:ice_staff.meow",
            "materials": {
                "default": "entity_alphatest",
                "enchanted": "entity_alphatest_glint"
            },
            "textures": {
                "default": "textures/items/staffs/ice_staff",
                "enchanted": "textures/misc/enchanted_item_glint"
            },
            "geometry": {
                "default": "geometry.staff"
            },
            "animations": {
                "hold.first_person": "animation.staff.hold.first_person",
                "hold.third_person": "animation.staff.hold.third_person",
                "use": "animation.staff.use.first_person",
                "particle": "animation.staff.use.first_person"
            },
            "particle_effects": {
                "sparkle": "pog:ice_beam"
            },
            "scripts": {
                "animate": [
                    { "hold.first_person": "context.is_first_person && !q.is_using_item" },
                    { "hold.third_person": "!context.is_first_person" },
                    { "use": "query.is_using_item && ((query.max_durability - (query.max_durability - query.remaining_durability)) > 0)" },
                    { "particle": "context.is_first_person && query.is_using_item && ((query.max_durability - (query.max_durability - query.remaining_durability)) > 0)" }
                ]
            },
            "render_controllers": [ "controller.render.item_default" ]
        }
    }
}