{
    "hud_actionbar_text/actionbar_message": {
        "$atext": "$actionbar_text",
        "visible": "(not (('%.6s' * $atext) = 'wawla;'))"
    },

    "anim_wawla": {
		"anim_type": "alpha",
		"easing": "in_expo",
		"duration": 0.32,
		"from": 0.92,
		"to": 0.92,
		"destroy_at_end": "hud_actionbar_text"
	},
	"anim_wawla_background": {
		"anim_type": "alpha",
		"easing": "in_expo",
		"duration": 0.32,
		"from": 0.92,
		"to": 0.92,
		"destroy_at_end": "hud_actionbar_text"
	},
    "wawla": {
        "type": "panel",
        "controls": [
            {
                "background": {
                    "type": "image",
                    "size": [
                        "100%c + 12px",
                        "100%c + 5px"
                    ],
                    "anchor_from": "top_middle",
                    "offset": [ 0, "32px" ],
                    "texture": "textures/ui/wawlaBorder",
                    "alpha": "@hud.anim_wawla_background",
                    "$atext": "$actionbar_text",
                    "visible": "(('%.6s' * $atext) = 'wawla;')",
                    "controls": [
                        {
                            "actionbar_message": {
                                "type": "label",
                                "layer": 31,
                                "anchor_from": "center",
                                "anchor_to": "center",
            
                                "color": "$tool_tip_text",
                                "$atext": "$actionbar_text",
                                "$actionbar": "($atext - 'wawla;')",
                                "text": "$actionbar",
                                "localize": true,
                                "alpha": "@hud.anim_wawla"
                            }
                        }
                    ]
                }
            }
		]
    },

    "wawla_factory": {
        "type": "panel",
        "layer": 30,
        "factory": {
            "name": "hud_actionbar_text_factory",
            "control_ids": {
                "hud_actionbar_text": "wawla@hud.wawla"
            }
        }
    },

    "chat_label": {
        "modifications": [
            {
                "array_name": "bindings",
                "operation": "insert_back",
                "value": {
                    "binding_type": "view",
                    "source_property_name": "(not (('%.10s' * #text) = 'bob.toast;'))",
                    "target_property_name": "#visible"
                }
            }
        ]
    },
    "toasty": {
        "type": "panel",
        "anchor_from": "top_right",
        "anchor_to": "top_right",
        "size": [ "100%", "100%c" ],
        "max_size": [ "100%", "50%" ],
        "controls": [
            {
                "stack_panel": {
                    "type": "stack_panel",
                    "anchor_from": "top_right",
                    "anchor_to": "top_right",
                    "use_child_anchors": true,
                    "factory": {
                        "name": "chat_item_factory",
                        "max_children_size": 50,
                        "control_ids": {
                            "chat_item": "achievement_stacked@hud.achievement_stacked"
                        }
                    }
                }
            }
        ]
    },

    "advancement_animation_in": {
        "anim_type": "offset",
        "easing": "out_quart",
        "duration": 1.0,
        "from": [ "14% + 180px", 30 ],
        "to": [ 0, 30 ],
        "next": "@hud.advancement_animation_stay"
    },
    "advancement_animation_stay": {
        "anim_type": "wait",
        "duration": 6.7,
        "next": "@hud.advancement_animation_out"
    },
    "advancement_animation_out": {
        "anim_type": "offset",
        "easing": "in_quart",
        "duration": 1.0,
        "from": [ 0, 30 ],
        "to": [ "14% + 180px", 30 ],
        "destroy_at_end": "chat_grid_item"
    },

    "achievement_element": {
        "layer": 1,
        "type": "image",
        "texture": "textures/ui/achievement_temp",
        "anims": [ "@hud.advancement_animation_in" ],

        "$unlock_key|default": "unknown",
        "$content_text|default": "Unknown",
        "$advancement_text|default": "Unknown",
        "$advancement_icon|default": "textures/ui/crafting",

        "clips_children": true,
        "anchor_from": "bottom_right",
        "anchor_to": "bottom_right",
                    
        "offset": [ 0, 33 ],
        "size": [ 163, 32 ],
        "uv_size": [ 163, 32 ],
        "$uv|default": [ 0, 0 ],
        "uv": "$uv",
        "controls": [
            {
                "advancement_icon_texture": {
                    "type": "image",
                    "texture": "$advancement_icon",
                    "layer": 3,
                    "anchor_from": "right_middle",
                    "anchor_to": "right_middle",
                    "offset": [
                        "-80%",
                        "-2.4%"
                    ],
                    "size": [ 19, 19 ]
                }
            },
            {
                "advancement_title": {
                    "type": "label",
                    "color": "$main_header_text_color",
                    "layer": 2,
                    "shadow": true,
                    "offset": [ "24%", -5 ],
                    "text": "$advancement_text",
                    "size": [ "default", 12 ],
                    "max_size": [ "100%", "100%" ],
                    "anchor_from": "left_middle",
                    "anchor_to": "left_middle"
                }
            },
            {
                "advancement_content_texts": {
                    "type": "label",
                    "shadow": true,
                    "anchor_from": "left_middle",
                    "anchor_to": "left_middle",
                    "color": "$main_header_text_color",
                    "text": "$content_text",
                    "layer": 2,
                    "offset": [ "24%", 5 ]
                }
            }
        ],
        "bindings": [
            {
                "binding_name": "#chat_text",
                "binding_name_override": "#text",
                "binding_type": "collection",
                "binding_collection_name": "chat_text_grid",
                "binding_condition": "once"
            },
            {
                "binding_type": "view",
                "source_property_name": "((('%.10s' * #text) = 'bob.toast;') and ((#text - ('%.10s' * #text)) = $unlock_key))",
                "target_property_name": "#visible"
            }
        ]
    },

