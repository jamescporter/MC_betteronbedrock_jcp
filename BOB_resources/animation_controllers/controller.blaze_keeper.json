{
	"format_version": "1.10.0",
	"animation_controllers": {
		"controller.animation.blaze_keeper.new": {
			"states": {
				"default": {
					"animations": [
						"idle"
					],
					"transitions": [
						{
							"active": "query.property('pog:attack_type') == 'ranged'"
						},
						{
							"active2": "query.property('pog:attack_type') == 'flame_beam'"
						},
						{
							"fire_aura_attack": "query.property('pog:attack_type') == 'fire_aura'"
						}
					],
					"blend_transition": 0.2
				},
				"active": {
					"animations": [
						"attack"
					],
					"transitions": [
						{
							"default": "query.variant == 1"
						},
						{
							"active2": "query.property('pog:attack_type') == 'flame_beam'"
						},
						{
							"fire_aura_attack": "query.property('pog:attack_type') == 'fire_aura'"
						}
					],
					"blend_transition": 0.2
				},
				"active2": {
					"animations": [
						"attack2"
					],
					"transitions": [
						{
							"default": "query.variant == 1"
						},
						{
							"active": "query.property('pog:attack_type') == 'ranged'"
						},
						{
							"fire_aura_attack": "query.property('pog:attack_type') == 'fire_aura'"
						}
					],
					"blend_transition": 0.2
				},
				"fire_aura_attack": {
					"animations": [
						"fire_aura_attack",
						"attack2"
					],
					"transitions": [
						{
							"default": "query.variant == 1"
						},

						{
							"active": "query.property('pog:attack_type') == 'ranged'"
						},
						{
							"active2": "query.property('pog:attack_type') == 'flame_beam'"
						}
					],
					"blend_transition": 0.2
				}
			}
		}
	}
}