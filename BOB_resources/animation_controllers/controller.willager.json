{
    "format_version": "1.19.0",
    "animation_controllers": {
        "controller.animation.geometry.willager": {
            "states": {
                "default": {
                    "animations": ["general"],
                    "transitions": [
                        { "default": "q.modified_move_speed > 0.05" },
                        { "casting": "q.is_casting" }
                    ],
                    "blend_transition": 0.2
                },
                "walking": {
                    "animations": ["move"],
                    "transitions": [
                        { "default": "q.modified_move_speed < 0.05" },
                        { "casting": "q.is_casting" }
                    ],
                    "blend_transition": 0.2
                },
                "casting": {
                    "animations": ["casting"],
                    "particle_effects": [
                        {
                            "effect": ""
                        }
                    ],
                    "transitions": [{ "default": "!q.is_casting" }],
                    "blend_transition": 0.2
                }
            }
        },
        "controller.animation.willager.general": {
            "initial_state": "default",
            "states": {
                "casting": {
                    "animations": ["look_at_target", "casting"],
                    "particle_effects": [
                        {
                            "effect": "spell",
                            "locator": "left_hand"
                        },
                        {
                            "effect": "spell",
                            "locator": "right_hand"
                        }
                    ],
                    "transitions": [
                        {
                            "default": "!query.is_casting"
                        }
                    ]
                },
                "default": {
                    "animations": ["look_at_target", "general"],
                    "blend_transition": 0.2,
                    "blend_via_shortest_path": true,
                    "transitions": [
                        {
                            "casting": "query.is_casting"
                        }
                    ]
                }
            }
        },
        "controller.animation.willager.general.v1.0": {
            "initial_state": "default",
            "states": {
                "casting": {
                    "animations": ["look_at_target", "casting"],
                    "particle_effects": [
                        {
                            "effect": "spell",
                            "locator": "left_hand"
                        },
                        {
                            "effect": "spell",
                            "locator": "right_hand"
                        }
                    ],
                    "transitions": [
                        {
                            "default": "!query.is_casting"
                        }
                    ]
                },
                "default": {
                    "animations": ["look_at_target", "general"],
                    "transitions": [
                        {
                            "casting": "query.is_casting"
                        }
                    ]
                }
            }
        }
    }
}
