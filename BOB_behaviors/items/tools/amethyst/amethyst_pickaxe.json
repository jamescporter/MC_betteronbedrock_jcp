{
    "format_version": "1.21.10",
    "minecraft:item": {
        "description": {
            "identifier": "better_on_bedrock:amethyst_pickaxe",
            "menu_category": {
                "category": "equipment",
                "group": "itemGroup.name.pickaxe"
            }
        },
        "components": {
            "minecraft:icon": "better_on_bedrock:amethyst_pickaxe",
            "minecraft:display_name": {
                "value": "item.better_on_bedrock:amethyst_pickaxe.name"
            },

            "minecraft:enchantable": {
                "value": 5,
                "slot": "pickaxe"
            },
            "minecraft:durability": {
                "max_durability": 350,
                "damage_chance": {
                    "min": 5,
                    "max": 10
                }
            },
            "minecraft:repairable": {
                "repair_items": [
                    {
                        "items": [ "minecraft:amethyst_shard" ],
                        "repair_amount": "q.max_durability * 0.25"
                    },
                    {
                        "items": [ "better_on_bedrock:amethyst_pickaxe" ],
                        "repair_amount": "c.other->q.remaining_durability + (0.12 * c.other->q.max_durability)"
                    }
                ]
            },

            "minecraft:damage": 3,
            "minecraft:max_stack_size": 1,
            "minecraft:hand_equipped": true,
            "minecraft:custom_components": [ "pog:tool_durability" ],
            "minecraft:tags": {
                "tags": [
                    "minecraft:is_pickaxe",
                    "better_on_bedrock:amethyst_tier"
                ]
            },

            "minecraft:digger": {
                "destroy_speeds": [
                    {
                        "block": {
                            "tags": "q.any_tag('minecraft:is_pickaxe_item_destructible') && !q.all_tags('minecraft:diamond_tier_destructible')"
                        },
                        "speed": 7
                    },
                    {
                        "block": {
                            "tags": "q.any_tag('stone_pick_diggable','iron_pick_diggable')"
                        },
                        "speed": 7
                    }
                ]
            }
        }
    }
}
