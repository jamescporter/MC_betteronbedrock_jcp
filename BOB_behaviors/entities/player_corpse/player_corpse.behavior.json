{
    "format_version": "1.20.30",
    "minecraft:entity": {
        "description": {
            "identifier": "better_on_bedrock:player_corpse",
            "is_spawnable": false,
            "is_summonable": true,
            "is_experimental": false
        },
        "components": {
            "minecraft:health": {
                "value": 1,
                "max": 5
            },
            "minecraft:tick_world": {
                "never_despawn": true,
                "radius": 3
            },
            "minecraft:equipment": {},
            "minecraft:physics": {},
            "minecraft:pushable": {
                "is_pushable": false,
                "is_pushable_by_piston": false
            },
            
            "minecraft:behavior.pickup_items": {
                "priority": 0,
                "max_dist": 32,
                "search_height": 32,
                "goal_radius": 3,
                "can_pickup_any_item": true,
                "can_pickup_to_hand_or_equipment": true
            },
            "minecraft:item_hopper": {},
            "minecraft:equip_item": {},
            "minecraft:behavior.equip_item": {
                "priority": 2
            },
            "minecraft:shareables": {
                "all_items": true,
                "all_items_want_amount": 1,
                "items": [
                    { "item": "minecraft:air", "priority": 0, "max_amount": 1 }
                ]
            },
            "minecraft:inventory": {
                "container_type": "inventory",
                "inventory_size": 54,
                "restrict_to_owner": false
            },
            "minecraft:collision_box": {
                "height": 1,
                "width": 1
            },
            "minecraft:custom_hit_test": {
                "hitboxes": [
                    {
                        "width": 1.5,
                        "height": 1.5,
                        "pivot": [ 0, 1, 0 ]
                    }
                ]
            },
            "minecraft:nameable": {
                "allow_name_tag_renaming": false,
                "always_show": true
            },
            "minecraft:damage_sensor": {
                "triggers": [{ "cause": "all", "deals_damage": false }]
            },
            "minecraft:conditional_bandwidth_optimization": {}
        },
        "component_groups": {
            "transform_entity": {
                "minecraft:timer": {
                    "time": 1.2,
                    "looping": false,
                    "time_down_event": {
                        "event": "delete_corpse",
                        "target": "self"
                    }
                },
                "minecraft:damage_sensor": {
                    "triggers": [{ "cause": "all", "deals_damage": false }]
                }
            },
            "delete_corpse": {
                "minecraft:transformation": {
                    "into": "minecraft:xp_orb",
                    "drop_equipment": true,
                    "drop_inventory": true,
                    "preserve_equipment": false
                }
            }
        },
        "events": {
            "delete_corpse": {
                "add": {
                    "component_groups": [ "delete_corpse" ]
                }
            },
            "minecraft:entity_spawned": {
                "queue_command": {
                    "command": [ "tp @e[type=item, r=5] @s" ]
                }
            },
            "entity_transform": {
                "add": {
                    "component_groups": [ "transform_entity" ]
                }
            }
        }
    }
}