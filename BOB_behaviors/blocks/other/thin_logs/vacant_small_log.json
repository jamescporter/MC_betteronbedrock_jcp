{
	"format_version": "1.26.0",
	"minecraft:block": {
		"description": {
			"identifier": "better_on_bedrock:vacant_small_log",
			"menu_category": {
				"category": "nature"
			},
			"traits": {
				"minecraft:placement_position": {
					"enabled_states": [ "minecraft:block_face" ]
				}
			},
			"states": {
				"better_on_bedrock:stripped": [ false, true ],
				"better_on_bedrock:connected_north": [ false, true ],
				"better_on_bedrock:connected_south": [ false, true ],
				"better_on_bedrock:connected_east": [ false, true ],
				"better_on_bedrock:connected_west": [ false, true ]
			}
		},
		"components": {
			"minecraft:geometry": {
				"identifier": "geometry.small_log",
				"bone_visibility": {
					"north": "q.block_state('better_on_bedrock:connected_north') == true",
					"south": "q.block_state('better_on_bedrock:connected_south') == true",
					"east": "q.block_state('better_on_bedrock:connected_east') == true",
					"west": "q.block_state('better_on_bedrock:connected_west') == true"
				}
			},
			"minecraft:material_instances": {
				"*": {
					"texture": "small_log_vacant_side",
					"render_method": "opaque"
				},
				"top": {
					"texture": "small_log_vacant_top",
					"render_method": "opaque"
				}
			},
			"minecraft:custom_components": [ "pog:small_logs" ],
			
            "minecraft:liquid_detection": {
                "detection_rules": [
                    {
                        "can_contain_liquid": true,
                        "liquid_type": "water"
                    }
                ]
            },
			"minecraft:collision_box": {
				"origin": [ -5, 0, -5 ],
				"size": [ 10, 16, 10 ]
			},
			"minecraft:selection_box": {
				"origin": [ -5, 0, -5 ],
				"size": [ 10, 16, 10 ]
			},
			"minecraft:destructible_by_mining": {
				"seconds_to_destroy": 1
			},
			"minecraft:destructible_by_explosion": {
				"explosion_resistance": 30
			},
            
            "tag:wood": {},
            "tag:log": {},
            "tag:better_on_bedrock:small_log": {},
            "tag:minecraft:is_axe_item_destructible": {}
		},
		"permutations": [
			{
				"condition": "q.block_state('minecraft:block_face') == 'up' || q.block_state('minecraft:block_face') == 'down'",
				"components": {
					"minecraft:transformation": {
						"rotation": [ 0, 0, 0 ]
					}
				}
			},
			{
				"condition": "q.block_state('minecraft:block_face') == 'east' || q.block_state('minecraft:block_face') == 'west'",
				"components": {
					"minecraft:transformation": {
						"rotation": [ 0, 0, 90 ]
					}
				}
			},
			{
				"condition": "q.block_state('minecraft:block_face') == 'north' || q.block_state('minecraft:block_face') == 'south'",
				"components": {
					"minecraft:transformation": {
						"rotation": [ 90, 0, 0 ]
					}
				}
			},
			{
				"condition": "query.block_state('better_on_bedrock:stripped') == 'true'",
				"components": {
					/*"minecraft:material_instances": {
						"*": {
							"texture": "small_log_vacant_stripped_side",
							"render_method": "opaque"
						},
						"top": {
							"texture": "small_log_vacant_stripped_top",
							"render_method": "opaque"
						}
					}*/
				}
			}
		]
	}
}