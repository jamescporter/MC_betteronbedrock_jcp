{
    "format_version": "1.21.40",
    "minecraft:block": {
        "description": {
            "identifier": "better_on_bedrock:stardust_block",
            "menu_category": {
                "category": "construction",
                "group": "itemGroup.name.oreBlocks"
            },
            "traits": {
                "minecraft:placement_direction": {
                    "enabled_states": [ "minecraft:cardinal_direction" ]
                }
            }
        },
        "components": {
            "minecraft:geometry": {
                "identifier": "minecraft:geometry.full_block"
            },
            "minecraft:material_instances": {
                "*": {
                    "texture": "better_on_bedrock:stardust_block"
                }
            },

            "minecraft:destructible_by_explosion": false,
            "minecraft:destructible_by_mining": {
                "seconds_to_destroy": 10,
                "item_specific_speeds": [
                    {
                        "item": {
                            "tags": "query.all_tags('minecraft:is_pickaxe','minecraft:diamond_tier')"
                        },
                        "destroy_speed": 1.5
                    },
                    {
                        "item": {
                            "tags": "query.all_tags('minecraft:is_pickaxe','minecraft:netherite_tier')"
                        },
                        "destroy_speed": 1.25
                    }
                ]
            },

            "tag:metal": {},
            "tag:diamond_pick_diggable": {}
        },
        "permutations": [
            {
                "condition": "q.block_state('minecraft:cardinal_direction') == 'north'",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [ 0, 0, 0 ]
                    }
                }
            },
            {
                "condition": "q.block_state('minecraft:cardinal_direction') == 'south'",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [ 0, 180, 0 ]
                    }
                }
            },
            {
                "condition": "q.block_state('minecraft:cardinal_direction') == 'east'",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [ 0, 270, 0 ]
                    }
                }
            },
            {
                "condition": "q.block_state('minecraft:cardinal_direction') == 'west'",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [ 0, 90, 0 ]
                    }
                }
            }
        ]
    }
}