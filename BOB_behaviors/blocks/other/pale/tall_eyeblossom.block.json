{
    "format_version": "1.26.0",
    "minecraft:block": {
        "description": {
            "identifier": "better_on_bedrock:tall_eyeblossom",
            "states": {
                "pog:double_plant": [ "default", "top_bit" ],
                "pog:is_open": [ false, true ]
            }
        },
        "components": {
            "minecraft:geometry": "geometry.better_on_bedrock.cross",
            "minecraft:material_instances": {
                "*": {
                    "texture": "better_on_bedrock:tall_eyeblossom_close_bottom",
                    "render_method": "alpha_test",
                    "ambient_occlusion": false,
                    "face_dimming": false
                }
            },
            "minecraft:map_color": "#32a852",
            "minecraft:collision_box": false,
            "minecraft:selection_box": {
                "origin": [ -3, 0, -3 ],
                "size": [ 6, 16, 6 ]
            },
            "minecraft:placement_filter": {
                "conditions": [
                    {
                        "allowed_faces": [ "up" ],
                        "block_filter": [
                            "grass_block",
                            "dirt",
                            "pale_moss_block",
                            "better_on_bedrock:tall_eyeblossom"
                        ]
                    }
                ]
            },
            "minecraft:tick": {
                "interval_range": [ 40, 80 ],
                "looping": true
            },
            "minecraft:custom_components": [
                "pog:open_blossom",
                "content:turn_to_air"
            ]
        },
        "permutations": [
            {
                "condition": "q.block_state('pog:double_plant') == 'default'",
                "components": {
                    "minecraft:loot": "loot_tables/empty.json"
                }
            },
            {
                "condition": "q.block_state('pog:double_plant') == 'top_bit'",
                "components": {
                    "minecraft:placement_filter": {
                        "conditions": [
                            {
                                "allowed_faces": [ "up" ],
                                "block_filter": [ "better_on_bedrock:tall_eyeblossom" ]
                            }
                        ]
                    }
                }
            },
            {
                "condition": "q.block_state('pog:is_open') == true",
                "components": {
                    "minecraft:light_emission": 1
                }
            },
            
            {
                "condition": "q.block_state('pog:double_plant') == 'top_bit' && !q.block_state('pog:is_open')",
                "components": {
                    "minecraft:material_instances": {
                        "*": {
                            "texture": "better_on_bedrock:tall_eyeblossom_close_top",
                            "render_method": "alpha_test",
                            "ambient_occlusion": false,
                            "face_dimming": false
                        }
                    }
                }
            },
            {
                "condition": "q.block_state('pog:double_plant') == 'default' && q.block_state('pog:is_open') == true",
                "components": {
                    "minecraft:material_instances": {
                        "*": {
                            "texture": "better_on_bedrock:tall_eyeblossom_open_bottom",
                            "render_method": "alpha_test",
                            "ambient_occlusion": false,
                            "face_dimming": false
                        }
                    }
                }
            },
            {
                "condition": "q.block_state('pog:double_plant') == 'top_bit' && q.block_state('pog:is_open') == true",
                "components": {
                    "minecraft:material_instances": {
                        "*": {
                            "texture": "better_on_bedrock:tall_eyeblossom_open_top",
                            "render_method": "alpha_test",
                            "ambient_occlusion": false,
                            "face_dimming": false
                        }
                    }
                }
            }
        ]
    }
}