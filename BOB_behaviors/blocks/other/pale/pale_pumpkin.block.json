{
    "format_version": "1.26.0",
    "minecraft:block": {
        "description": {
            "identifier": "better_on_bedrock:pale_pumpkin",
            "menu_category": {
                "category": "nature"
            },
            "traits": {
                "minecraft:placement_direction": {
                    "enabled_states": [ "minecraft:cardinal_direction" ]
                }
            },
            "states": {
                "pog:is_open": [ false, true ]
            }
        },
        "components": {
            "minecraft:destructible_by_mining": {
                "seconds_to_destroy": 2.4
            },
            "minecraft:destructible_by_explosion": {
                "explosion_resistance": 15
            },
            "minecraft:flammable": {
                "destroy_chance_modifier": 20,
                "catch_chance_modifier": 5
            },
            "minecraft:geometry": "minecraft:geometry.full_block",
            "minecraft:material_instances": {
                "*": {
                    "texture": "better_on_bedrock:pale_pumpkin_side",
                    "render_method": "opaque"
                },
                "better_on_bedrock:top_texture": {
                    "texture": "better_on_bedrock:pale_pumpkin_top",
                    "render_method": "opaque"
                },
                "up": "better_on_bedrock:top_texture",
                "down": "better_on_bedrock:top_texture",
                "north": {
                    "texture": "better_on_bedrock:pale_pumpkin_face_off",
                    "render_method": "opaque"
                }
            },
            "minecraft:custom_components": [
                "pog:open_pumkin"
            ],
            "minecraft:tick": {
                "interval_range": [ 20, 80 ],
                "looping": true
            },
            "minecraft:map_color": "#5f4a2b",
            "tag:pumpkin": {},
            "tag:minecraft:is_axe_item_destructible": {}
        },
        "permutations": [
            {
                "condition": "q.block_state('pog:is_open') == true",
                "components": {
                    "minecraft:light_emission": 1,
                    "minecraft:light_dampening": 15
                }
            },
            {
                "condition": "q.block_state('minecraft:cardinal_direction') == 'north'",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [ 0, 180, 0 ]
                    }
                }
            },
            {
                "condition": "q.block_state('minecraft:cardinal_direction') == 'south'",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [ 0, 0, 0 ]
                    }
                }
            },
            {
                "condition": "q.block_state('minecraft:cardinal_direction') == 'east'",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [ 0, 90, 0 ]
                    }
                }
            },
            {
                "condition": "q.block_state('minecraft:cardinal_direction') == 'west'",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [ 0, 270, 0 ]
                    }
                }
            }
