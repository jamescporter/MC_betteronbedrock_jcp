{
    "format_version": "1.26.0",
    "minecraft:block": {
        "description": {
            "identifier": "better_on_bedrock:bluegrod",
            "states": {
                "pog:double_plant": [ "default", "top_bit" ]
            }
        },
        "components": {
            "minecraft:geometry": "geometry.better_on_bedrock.cross",
            "minecraft:material_instances": {
                "*": {
                    "texture": "bluegrod_bottom",
                    "render_method": "alpha_test",
                    "ambient_occlusion": false,
                    "face_dimming": false
                }
            },
            "minecraft:liquid_detection": {
                "detection_rules": [
                    {
                        "can_contain_liquid": false,
                        "liquid_type": "water",
                        "on_liquid_touches": "popped"
                    }
                ]
            },
            "minecraft:map_color": "#32a852",
            "minecraft:collision_box": false,
            "minecraft:selection_box": {
                "origin": [ -3, 0, -3 ],
                "size": [ 6, 16, 6 ]
            },
            "minecraft:placement_filter": {
                "conditions": [
                    {
                        "allowed_faces": [ "up" ],
                        "block_filter": [
                            "grass_block",
                            "dirt"
                        ]
                    }
                ]
            },

            "minecraft:custom_components": [ "content:turn_to_air" ]
        },
        "permutations": [
            {
                "condition": "q.block_state('pog:double_plant') == 'default'",
                "components": { "minecraft:loot": "loot_tables/empty.json" }
            },
            {
                "condition": "q.block_state('pog:double_plant') == 'top_bit'",
                "components": {
                    "minecraft:material_instances": {
                        "*": {
                            "texture": "bluegrod_top",
                            "render_method": "alpha_test",
                            "ambient_occlusion": false,
                            "face_dimming": false
                        }
                    },
                    "minecraft:placement_filter": {
                        "conditions": [
                            {
                                "allowed_faces": [ "up" ],
                                "block_filter": [ "better_on_bedrock:bluegrod" ]
                            }
                        ]
                    }
                }
            }
        ]
    }
}