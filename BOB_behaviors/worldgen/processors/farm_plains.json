/*This processor changes the wheat crop insdie of villgrowth farms to any crop listed in here randomly*/
{
  "format_version": "1.21.20",
  "minecraft:processor_list": {
    "description": {
      "identifier": "minecraft:farm_plains"
    },
    "processors": [
      {
        "processor_type": "minecraft:rule",
        "rules": [
          {
            "input_predicate": {
              "block": "minecraft:wheat",
              "predicate_type": "minecraft:random_block_match",
              "probability": 0.3
            },
            "location_predicate": {
              "predicate_type": "minecraft:always_true"
            },
            "output_state": {
              "name": "minecraft:stone"
            }
          }
        ]
      }
    ]
  }
}